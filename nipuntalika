    private void applyFilter() {
        classWiseStudentsList.clear();

        for (StudentModel student : allStudentsList) {
            if (student.getClassId() == selectedClassId) {
                classWiseStudentsList.add(student);
            }
        }

        filteredCompetencyList.clear();

        String query = searchText.toLowerCase(Locale.ROOT);

        for (CompetencyModel competency : allCompetencyList) {
            boolean classMatched = competency.getClassId() == selectedClassId;
            boolean subjectMatched = competency.getSubjectId() == selectedSubjectId;

            boolean searchMatched =
                    competency.getCompetencyName().toLowerCase(Locale.ROOT).contains(query)
                            || competency.getLoCode().toLowerCase(Locale.ROOT).contains(query);

            if (classMatched && subjectMatched && searchMatched) {
                filteredCompetencyList.add(competency);
            }
        }

        updateCount();

        if (competencyAdapter != null) {
            competencyAdapter.notifyDataSetChanged();
        }
    }

    private void updateCount() {
        tvListTitle.setText(selectedClassName + " - " + selectedSubjectName);

        tvTotalCount.setText(
                "Competency: " + filteredCompetencyList.size()
                        + " | Students: " + classWiseStudentsList.size()
        );
    }

    private void saveSurveyData() {
        int totalChecked = 0;

        StringBuilder builder = new StringBuilder();
        builder.append("Survey Saved\n\n");
        builder.append("Class ID: ").append(selectedClassId).append("\n");
        builder.append("Class: ").append(selectedClassName).append("\n");
        builder.append("Subject ID: ").append(selectedSubjectId).append("\n");
        builder.append("Subject: ").append(selectedSubjectName).append("\n\n");

        for (CompetencyModel competency : allCompetencyList) {
            Set<Integer> selectedStudents = competencyStudentSelectionMap.get(competency.getCompetencyId());

            if (selectedStudents != null && !selectedStudents.isEmpty()) {
                builder.append("LO Code: ")
                        .append(competency.getLoCode())
                        .append("\n");

                builder.append("Competency ID: ")
                        .append(competency.getCompetencyId())
                        .append("\n");

                builder.append("Competency: ")
                        .append(competency.getCompetencyName())
                        .append("\n");

                for (StudentModel student : allStudentsList) {
                    if (selectedStudents.contains(student.getStudentId())) {
                        totalChecked++;

                        builder.append(" - Student ID: ")
                                .append(student.getStudentId())
                                .append(", ")
                                .append(student.getStudentName())
                                .append(" (")
                                .append(student.getClassName())
                                .append(")")
                                .append("\n");
                    }
                }

                builder.append("\n");
            }
        }

        if (totalChecked == 0) {
            Toast.makeText(this, "Please select at least one student", Toast.LENGTH_SHORT).show();
            return;
        }

        Toast.makeText(this, builder.toString(), Toast.LENGTH_LONG).show();

        /*
         * Save this mapping into SQLite/local database:
         *
         * For every selected student under every competency:
         *
         * competency_id
         * lo_code
         * class_id
         * subject_id
         * student_id
         * is_checked = 1
         *
