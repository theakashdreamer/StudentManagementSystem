         *                 studentId,
         *                 1
         *             );
         *         }
         *     }
         * }
         */
    }


    public interface ParentRefreshListener {
        void onParentRefresh();
    }

    public class CompetencyAdapter extends RecyclerView.Adapter<CompetencyAdapter.CompetencyViewHolder> {

        private final ArrayList<CompetencyModel> competencyList;
        private final ArrayList<StudentModel> studentList;
        private final Map<Integer, Set<Integer>> selectionMap;

        public CompetencyAdapter(
                ArrayList<CompetencyModel> competencyList,
                ArrayList<StudentModel> studentList,
                Map<Integer, Set<Integer>> selectionMap
        ) {
            this.competencyList = competencyList;
            this.studentList = studentList;
            this.selectionMap = selectionMap;
        }

        @NonNull
        @Override
        public CompetencyViewHolder onCreateViewHolder(@NonNull ViewGroup parent, int viewType) {
            View view = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.item_competency_parent, parent, false);
            return new CompetencyViewHolder(view);
        }

        @Override
        public void onBindViewHolder(@NonNull CompetencyViewHolder holder, int position) {
            CompetencyModel competency = competencyList.get(position);

            holder.tvCompetencyNo.setText(String.format(Locale.getDefault(), "%02d", position + 1));

            holder.tvCompetencyName.setText(
                    competency.getLoCode() + " - " + competency.getCompetencyName()
            );

            Set<Integer> selectedStudents = selectionMap.get(competency.getCompetencyId());

            int selectedCount = selectedStudents == null ? 0 : selectedStudents.size();
            int totalStudents = studentList.size();

            holder.tvCompetencyInfo.setText(
                    selectedClassName + " • " + selectedSubjectName
                            + " • Selected " + selectedCount + "/" + totalStudents
            );

            if (selectedCount == 0) {
                holder.tvCompetencyStatus.setText("Pending");
                holder.tvCompetencyStatus.setTextColor(getResources().getColor(android.R.color.holo_red_dark));
                holder.cardCompetency.setCardBackgroundColor(getResources().getColor(android.R.color.white));
            } else if (selectedCount < totalStudents) {
                holder.tvCompetencyStatus.setText("Partial");
                holder.tvCompetencyStatus.setTextColor(getResources().getColor(android.R.color.holo_orange_dark));
                holder.cardCompetency.setCardBackgroundColor(getResources().getColor(android.R.color.white));
            } else {
                holder.tvCompetencyStatus.setText("Completed");
                holder.tvCompetencyStatus.setTextColor(getResources().getColor(android.R.color.holo_green_dark));
                holder.cardCompetency.setCardBackgroundColor(0xFFEAFBF0);
            }

            ChildStudentAdapter childStudentAdapter = new ChildStudentAdapter(
                    competency,
                    studentList,
                    selectionMap,
                    () -> {
                        int currentPosition = holder.getBindingAdapterPosition();
                        if (currentPosition != RecyclerView.NO_POSITION) {
                            notifyItemChanged(currentPosition);
                        }
                        updateCount();
                    }
            );

            holder.recyclerViewChildStudents.setLayoutManager(
                    new LinearLayoutManager(Nipun_Taliika_Activity.this)
            );

            holder.recyclerViewChildStudents.setNestedScrollingEnabled(false);
            holder.recyclerViewChildStudents.setAdapter(childStudentAdapter);
            holder.btnSaveCompetency.setOnClickListener(v -> {
                saveSingleCompetencyData(competency);

                int currentPosition = holder.getBindingAdapterPosition();
                if (currentPosition != RecyclerView.NO_POSITION) {
                    notifyItemChanged(currentPosition);
                }
            });
        }

        @Override
        public int getItemCount() {
            return competencyList.size();
        }

        public class CompetencyViewHolder extends RecyclerView.ViewHolder {

            CardView cardCompetency;
            TextView tvCompetencyNo, tvCompetencyName, tvCompetencyInfo, tvCompetencyStatus;
            RecyclerView recyclerViewChildStudents;
            MaterialButton btnSaveCompetency;

            public CompetencyViewHolder(@NonNull View itemView) {
                super(itemView);

                cardCompetency = itemView.findViewById(R.id.cardCompetency);
                tvCompetencyNo = itemView.findViewById(R.id.tvCompetencyNo);
                tvCompetencyName = itemView.findViewById(R.id.tvCompetencyName);
                tvCompetencyInfo = itemView.findViewById(R.id.tvCompetencyInfo);
                tvCompetencyStatus = itemView.findViewById(R.id.tvCompetencyStatus);
                recyclerViewChildStudents = itemView.findViewById(R.id.recyclerViewChildStudents);
                btnSaveCompetency = itemView.findViewById(R.id.btnSaveCompetency);
            }
        }
    }

    public class ChildStudentAdapter extends RecyclerView.Adapter<ChildStudentAdapter.ChildStudentViewHolder> {

        private final CompetencyModel competency;
        private final ArrayList<StudentModel> studentList;
        private final Map<Integer, Set<Integer>> selectionMap;
        private final ParentRefreshListener parentRefreshListener;

        public ChildStudentAdapter(
                CompetencyModel competency,
                ArrayList<StudentModel> studentList,
                Map<Integer, Set<Integer>> selectionMap,
                ParentRefreshListener parentRefreshListener
        ) {
            this.competency = competency;
            this.studentList = studentList;
            this.selectionMap = selectionMap;
            this.parentRefreshListener = parentRefreshListener;
        }

        @NonNull
        @Override
        public ChildStudentViewHolder onCreateViewHolder(@NonNull ViewGroup parent, int viewType) {
            View view = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.item_student_survey, parent, false);
            return new ChildStudentViewHolder(view);
        }

        @Override
        public void onBindViewHolder(@NonNull ChildStudentViewHolder holder, int position) {
            StudentModel student = studentList.get(position);

            holder.tvRollNo.setText(String.format(Locale.getDefault(), "%02d", student.getRollNo()));
            holder.tvStudentName.setText(student.getStudentName());
            holder.tvStudentClass.setText(student.getClassName());

            Set<Integer> selectedStudents = selectionMap.get(competency.getCompetencyId());

            boolean isChecked = selectedStudents != null
                    && selectedStudents.contains(student.getStudentId());

            holder.checkBoxStudent.setOnCheckedChangeListener(null);
            holder.checkBoxStudent.setChecked(isChecked);

            holder.checkBoxStudent.setOnCheckedChangeListener((buttonView, checked) -> {
                Set<Integer> currentSet = selectionMap.get(competency.getCompetencyId());

                if (currentSet == null) {
                    currentSet = new HashSet<>();
                    selectionMap.put(competency.getCompetencyId(), currentSet);
                }

                if (checked) {
                    currentSet.add(student.getStudentId());
                } else {
                    currentSet.remove(student.getStudentId());
                }

                if (parentRefreshListener != null) {
                    parentRefreshListener.onParentRefresh();
                }
            });

            holder.itemView.setOnClickListener(v -> {
                holder.checkBoxStudent.setChecked(!holder.checkBoxStudent.isChecked());
            });
        }

        @Override
        public int getItemCount() {
            return studentList.size();
        }

        public class ChildStudentViewHolder extends RecyclerView.ViewHolder {

            TextView tvRollNo, tvStudentName, tvStudentClass;
            CheckBox checkBoxStudent;

            public ChildStudentViewHolder(@NonNull View itemView) {
                super(itemView);

                tvRollNo = itemView.findViewById(R.id.tvRollNo);
                tvStudentName = itemView.findViewById(R.id.tvStudentName);
                tvStudentClass = itemView.findViewById(R.id.tvStudentClass);
                checkBoxStudent = itemView.findViewById(R.id.checkBoxStudent);
            }
        }
    }
}

