    /*
     * Key   = competencyId
     * Value = selected student IDs under this competency
     *
     * Example:
     * competencyId 1 -> [studentId 1, studentId 2]
     * competencyId 2 -> [studentId 1, studentId 4]
     */
    private final Map<Integer, Set<Integer>> competencyStudentSelectionMap = new HashMap<>();
    private void saveSingleCompetencyData(CompetencyModel competency) {
        Set<Integer> selectedStudents =
                competencyStudentSelectionMap.get(competency.getCompetencyId());

        if (selectedStudents == null || selectedStudents.isEmpty()) {
            Toast.makeText(
                    this,
                    "Please select at least one student for this competency",
                    Toast.LENGTH_SHORT
            ).show();
            return;
        }

        StringBuilder builder = new StringBuilder();

        builder.append("Competency Saved\n\n");
        builder.append("Competency ID: ")
                .append(competency.getCompetencyId())
                .append("\n");

        builder.append("LO Code: ")
                .append(competency.getLoCode())
                .append("\n");

        builder.append("Competency: ")
                .append(competency.getCompetencyName())
                .append("\n");

        builder.append("Class ID: ")
                .append(competency.getClassId())
                .append("\n");

        builder.append("Class: ")
                .append(selectedClassName)
                .append("\n");

        builder.append("Subject ID: ")
                .append(competency.getSubjectId())
                .append("\n");

        builder.append("Subject: ")
                .append(selectedSubjectName)
                .append("\n\n");

        builder.append("Selected Students:\n");

        for (StudentModel student : classWiseStudentsList) {
            if (selectedStudents.contains(student.getStudentId())) {
                builder.append("- Student ID: ")
                        .append(student.getStudentId())
                        .append(", ")
                        .append(student.getStudentName())
                        .append("\n");
            }
        }

        Toast.makeText(this, builder.toString(), Toast.LENGTH_LONG).show();

        /*
         * SQLite save logic example:
         *
         * 1. Delete old saved data for this competency + class + subject
         * 2. Insert fresh selected student rows
         *
         * DELETE FROM competency_student_result
         * WHERE competency_id = ?
         * AND class_id = ?
         * AND subject_id = ?;
         *
         * INSERT INTO competency_student_result (
         *     competency_id,
         *     lo_code,
         *     class_id,
         *     subject_id,
         *     student_id,
         *     is_checked,
         *     created_at,
         *     updated_at
         * ) VALUES (?, ?, ?, ?, ?, 1, datetime('now'), datetime('now'));
         */
    }
