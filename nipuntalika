        spinnerClass.setAdapter(classAdapter);
        spinnerSubject.setAdapter(subjectAdapter);

        spinnerClass.setSelection(0);
        spinnerSubject.setSelection(0);

        spinnerClass.setOnItemSelectedListener(new AdapterView.OnItemSelectedListener() {
            @Override
            public void onItemSelected(AdapterView<?> parent, View view, int position, long id) {
                ClassModel selectedClass = classList.get(position);

                selectedClassId = selectedClass.getClassId();
                selectedClassName = selectedClass.getClassName();

                applyFilter();
            }

            @Override
            public void onNothingSelected(AdapterView<?> parent) {
            }
        });

        spinnerSubject.setOnItemSelectedListener(new AdapterView.OnItemSelectedListener() {
            @Override
            public void onItemSelected(AdapterView<?> parent, View view, int position, long id) {
                SubjectModel selectedSubject = subjectList.get(position);

                selectedSubjectId = selectedSubject.getSubjectId();
                selectedSubjectName = selectedSubject.getSubjectName();

                applyFilter();
            }

            @Override
            public void onNothingSelected(AdapterView<?> parent) {
            }
        });
